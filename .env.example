# ─── Database (shared PostgreSQL) ─────────────────────────
DATABASE_URL="postgresql://optidept:ebrightoptidept2025@103.209.156.174:5433/ebright_hrfs?schema=public"

# ─── Redis (shared) ───────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Existing HRMS Auth (NextAuth) ────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-strong-secret-min-32-chars"

# ─── CRM Auth (Better Auth) ───────────────────────────────
BETTER_AUTH_SECRET="replace-with-strong-secret-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# ─── CRM Encryption (AES-256-GCM) ────────────────────────
# Must be exactly 64 hex chars (32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="replace_with_64_hex_characters_here_0000000000000000000000000000"

# ─── Resend (Email) ───────────────────────────────────────
CRM_RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
CRM_FROM_EMAIL="Ebright OSC <noreply@ebright.my>"

# ─── AWS S3 (Uploads/Exports) ─────────────────────────────
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="ap-southeast-1"
AWS_S3_BUCKET="ebright-crm-uploads"

# ─── Meta (Facebook / Instagram Lead Ads) ────────────────
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
CRM_META_VERIFY_TOKEN="your-random-webhook-verify-token"

# ─── TikTok Business ──────────────────────────────────────
TIKTOK_APP_ID="your-tiktok-app-id"
TIKTOK_APP_SECRET="your-tiktok-app-secret"

# ─── Google OAuth (Calendar + Sheets) ────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/crm/integrations/google/callback"

# ─── Microsoft / Outlook ──────────────────────────────────
MICROSOFT_CLIENT_ID="your-azure-app-client-id"
MICROSOFT_CLIENT_SECRET="your-azure-app-secret"
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/crm/integrations/outlook/callback"

# ─── Twilio WhatsApp ──────────────────────────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_WHATSAPP_FROM="+14155238886"

# ─── Web Push (VAPID) ─────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_EMAIL="admin@ebright.my"
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── AutoCount payroll API ────────────────────────────────
# (set on each environment)
AUTOCOUNT_API_TOKEN="set-in-environment"
# FA System — academy DB where studentrecords lives. Falls back to DATABASE_URL if unset.
FA_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5433/ebrightleads_db"
