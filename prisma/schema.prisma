  profitabilityTarget  Float                 @default(0)
  registrationDeadline DateTime?
  testRunDate          DateTime?
  currency             String                @default("MYR")
  isActive             Boolean               @default(false)
  departmentLeads      Json?
  goodieBagChecklist      Json?
  logisticsData           Json?
  sponsorPackages         Json?
  photographerGuidelines  Json?
  pressCoverage           Json?
  photoDistribution       Json?
  scoringCriteria         Json?
  stageChecklist          Json?
  youthpreneurLayout      Json?
  waitlistEnabled         Boolean               @default(false)
  waitlistCount           Int                   @default(0)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  members       ShowcaseMember[]
  participants  ShowcaseParticipant[]
  categories    ShowcaseCategory[]
  feeWaves      ShowcaseFeeWave[]
  tasks         ShowcaseTask[]
  budgetItems   ShowcaseBudgetItem[]
