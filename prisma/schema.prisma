generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Table for Login and Roles
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  role         String   @default("BRANCH_MANAGER")
  branchName   String?  
  createdAt    DateTime @default(now())
}

// 2. Table to replace localStorage for your schedules!
model ManpowerSchedule {
  id                 String   @id 
  branch             String
  startDate          String
  endDate            String
  selections         Json     
  notes              Json     
  originalSelections Json     
  originalNotes      Json     
  status             String   @default("Finalized")
  submittedAt        DateTime @default(now())
  originalAuthor     String
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  nickname  String?
  branch    String
  position  String?
  createdAt DateTime @default(now())

  @@unique([name, branch])
}

model BranchStaff {
  id        Int      @id @default(autoincrement())
  name      String
  branch    String   // e.g., 'Bandar Seri Putra' or 'Shah Alam'
  role      String?  // e.g., 'part_time_coach', 'branch_manager', etc.
  createdAt DateTime @default(now())

  @@unique([name, branch]) // Prevents adding the same person twice to the same branch
}