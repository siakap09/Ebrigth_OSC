// ============================================================
// TICKETING MODULE — tkt_* tables
// ============================================================

model tkt_platform {
  id           String   @id @default(uuid())
  tenant_id    String
  name         String
  slug         String
  code         String   // "01"-"05" used in ticket number generation
  accent_color String   @default("#6b7280")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user_platforms tkt_user_platform[]
  tickets        tkt_ticket[]
  counters       tkt_counter[]

  @@unique([tenant_id, slug])
  @@unique([tenant_id, name])
  @@index([tenant_id])
  @@map("tkt_platform")
}

model tkt_branch {
  id            String   @id @default(uuid())
  tenant_id     String
  name          String
  code          String   // e.g. "AMP"
  branch_number String   // "01".."26" zero-padded, stable
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user_branches tkt_user_branch[]
  tickets       tkt_ticket[]
  counters      tkt_counter[]

  @@unique([tenant_id, branch_number])
  @@unique([tenant_id, code])
  @@index([tenant_id])
  @@map("tkt_branch")
}

// Ticket-specific user profile (extends crm_auth_user via user_id FK)
model tkt_user_profile {
  user_id             String   @id
  tenant_id           String
  role                String   // "super_admin" | "platform_admin" | "user"
  email_notifications Boolean  @default(true)
  dark_theme          Boolean  @default(true)
  activity_updates    Boolean  @default(true)
  system_alerts       Boolean  @default(false)
  audit_logs          Boolean  @default(false)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  platforms tkt_user_platform[]
  branches  tkt_user_branch[]
  tickets   tkt_ticket[]

  @@index([tenant_id])
  @@index([tenant_id, role])
  @@map("tkt_user_profile")
}

model tkt_user_platform {
  user_id     String
  platform_id String

  profile  tkt_user_profile @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  platform tkt_platform     @relation(fields: [platform_id], references: [id], onDelete: Cascade)

  @@id([user_id, platform_id])
  @@map("tkt_user_platform")
}

model tkt_user_branch {
  user_id   String
  branch_id String

  profile tkt_user_profile @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  branch  tkt_branch       @relation(fields: [branch_id], references: [id], onDelete: Cascade)

  @@id([user_id, branch_id])
  @@map("tkt_user_branch")
}

model tkt_ticket {
  id                String    @id @default(uuid())
  ticket_number     String
  tenant_id         String
  branch_id         String
  platform_id       String
  user_id           String
  issue_context     String
  sub_type          String
  fields            Json
  status            String    @default("received") // received | in_progress | complete | rejected
  admin_remark      String?
  rejection_reason  String?
  assigned_admin_id String?
  completed_at      DateTime?
  visible_until     DateTime? // completed_at + 7 days; filtered server-side
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  platform    tkt_platform           @relation(fields: [platform_id], references: [id])
  branch      tkt_branch             @relation(fields: [branch_id], references: [id])
  submitter   tkt_user_profile       @relation(fields: [user_id], references: [user_id])
  attachments tkt_ticket_attachment[]
  events      tkt_ticket_event[]

  @@unique([tenant_id, ticket_number])
  @@index([tenant_id, platform_id, status])
  @@index([tenant_id, branch_id])
  @@index([tenant_id, user_id])
  @@map("tkt_ticket")
}

model tkt_ticket_attachment {
  id        String   @id @default(uuid())
  ticket_id String
  url       String
  filename  String
  size      Int
  mime_type String
  created_at DateTime @default(now())

  ticket tkt_ticket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@index([ticket_id])
  @@map("tkt_ticket_attachment")
}

model tkt_ticket_event {
  id        String   @id @default(uuid())
  ticket_id String
  event_type String
  description String?
  meta       Json?
  created_at DateTime @default(now())

  ticket tkt_ticket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@index([ticket_id])
  @@map("tkt_ticket_event")
}

model tkt_counter {
  id            String   @id @default(uuid())
  tenant_id     String
  platform_id   String
  branch_id     String?
  counter_type  String   // "ticket", "daily", etc.
  year          Int
  month         Int?
  day           Int?
  current_count Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  platform tkt_platform @relation(fields: [platform_id], references: [id])
  branch   tkt_branch?  @relation(fields: [branch_id], references: [id])

  @@unique([tenant_id, platform_id, branch_id, counter_type, year, month, day])
  @@index([tenant_id])
  @@map("tkt_counter")
}

// ============================================================
// BRANCH OPERATION DAYS — configurable per-branch operating day flags
// ============================================================

model BranchOperationDays {
  id        Int      @id @default(autoincrement())
  branch    String   @unique
  wed       Boolean  @default(true)
  thu       Boolean  @default(true)
  fri       Boolean  @default(true)
  sat       Boolean  @default(true)
  sun       Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("branch_operation_days")
}

// ============================================================
// BURNLIST — weekly snapshots of expired+active students from
// ebrightleads_db.studentrecords, with editable cta/remarks/done.
// Each Wednesday a new BurnlistWeek is created and a row is
// snapshotted per student. Entries store a frozen copy of
// name/branch/expiry so historical weeks stay stable even when
// the upstream studentrecords row changes.
// ============================================================

model BurnlistWeek {
  id        String   @id @default(cuid())
  weekKey   String   @unique  // YYYY-MM-DD of the Wednesday, e.g. "2026-05-20"
  createdAt DateTime @default(now())

  entries   BurnlistEntry[]

  @@map("burnlist_week")
}

model BurnlistEntry {
  id              String   @id @default(cuid())
  weekId          String
  week            BurnlistWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)

  // Snapshot fields — copied from studentrecords at snapshot time.
  studentRecordId String
  studentName     String
  branch          String   // raw branch code, e.g. "ST"
  expiryDate      String   // YYYY-MM-DD as Postgres held it

  // Editable action fields. Blank on snapshot; filled in by BMs / user.
  cta      String   @default("")    // "" | "Extend" | "Archive" | "Renew" | "No Action"
  remarks  String   @default("")
  done     Boolean  @default(false)

  updatedAt DateTime @updatedAt

  @@unique([weekId, studentRecordId])
  @@index([weekId])
  @@map("burnlist_entry")
}

// ============================================================
// ANNUAL SHOWCASE MODULE — showcase_* tables
// ============================================================

enum ShowcaseEditionStatus {
  DRAFT
  REGISTRATION_OPEN
  TEST_RUN
  EVENT_ACTIVE
  POST_EVENT
  ARCHIVED
}

enum ShowcaseTaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum ShowcaseTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ShowcaseBudgetType {
  REVENUE
  EXPENSE
}

enum ShowcaseBudgetItemStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum ShowcaseSponsorStatus {
  PROSPECT
  CONTACTED
  NEGOTIATING
  CONFIRMED
  DECLINED
  LEAD
  MEETING
  MOU_SIGNED
  FULFILLED
}

model ShowcaseEdition {
  id                   String                @id @default(cuid())
  name                 String
  theme                String
  status               ShowcaseEditionStatus @default(DRAFT)
  startDate            DateTime?
  endDate              DateTime?
  venueName            String?
