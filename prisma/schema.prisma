generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 6 still REQUIRES `url` here — `prisma validate` errors without it,
  // even though prisma.config.ts also defines datasource.url. The newer Prisma
  // VS Code extension (Prisma 7-aware) flags this line as deprecated, but that
  // warning is ahead of the installed CLI (6.19); removing it breaks the build.
  // Prisma 7 will move this to prisma.config.ts entirely — drop this line then.
  url      = env("DATABASE_URL")
}

// ============================================================
// EXISTING HRMS MODELS (do not modify)
// ============================================================

model User {
  id                   Int       @id @default(autoincrement())
  email                String    @unique
  passwordHash         String
  role                 String    @default("BRANCH_MANAGER")
  branchName           String?
  createdAt            DateTime  @default(now())
  name                 String?
  status               String    @default("ACTIVE")
  lastLoggedInAt       DateTime?
  // Per-user dashboard access overrides on top of the role default in
  // lib/dashboard-access.ts. Shape: { "hrms.attendance": "DENIED", "crm": "ALLOWED" }
  // Null/empty = follow the role default for every key.
  dashboardOverrides   Json?

  showcaseTasksAssigned       ShowcaseTask[]         @relation("ShowcaseTaskAssignee")
  showcaseTasksCreated        ShowcaseTask[]         @relation("ShowcaseTaskCreator")
  showcaseBudgetApproved      ShowcaseBudgetItem[]   @relation("ShowcaseBudgetApprover")
  showcaseAnnouncements           ShowcaseAnnouncement[]       @relation("ShowcaseAnnouncementAuthor")
  showcasePostMortems             ShowcasePostMortem[]         @relation("ShowcasePostMortemAuthor")
  showcaseOutreachLogs            ShowcaseSponsorOutreach[]    @relation("OutreachLogger")
  showcasePostMortemResponses     ShowcasePostMortemResponse[] @relation("PostMortemResponder")
}

// Tracks when a user's active sessions should be invalidated. Written by
// /api/auth/change-password on a successful password update; consulted by
// lib/nextauth.ts's jwt() callback and by middleware.ts on every page nav.
//
// Lives in the local `crm` schema (NOT on the User table) because crm."User"
// is an FDW view of ebright_hrfs.public."User" and the FDW source doesn't
// know about OSC's session lifecycle. Decoupling this row from the User
// model means OSC owns its own revocation history end-to-end.
model SessionRevocation {
  email        String   @id
  revokedAfter DateTime
}

model ManpowerSchedule {
  id                 String   @id
  branch             String
  startDate          String
  endDate            String
  selections         Json
  notes              Json
  originalSelections Json
  originalNotes      Json
  status             String   @default("Finalized")
  submittedAt        DateTime @default(now())
  originalAuthor     String
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  nickname  String?
  branch    String
  position  String?
  createdAt DateTime @default(now())
  CoachRate Decimal? @db.Decimal

  @@unique([name, branch])
}

model BranchStaff {
  id                 Int       @id @default(autoincrement())
  name               String?
  branch             String?
  createdAt          DateTime  @default(now())
  role               String?
  nickname           String?
  nric               String?
  dob                String?
  age                String?
  gender             String?
  nationality        String?
  home_address       String?
  phone              String?
  email              String?
  residential        String?
  emergency_name     String?
  emergency_phone    String?
  emergency_relation String?
  signed_date        String?
  start_date         String?
  employment_type    String?
  status             String?
  bank               String?
  bank_name          String?
  bank_account       String?
  university         String?
  department         String?
  position           String?
  location           String?
  accessStatus       String?   @default("AUTHORIZED")
  contract           String?
  employeeId         String?
  endDate            String?
  probation          String?
  rate               String?
  updatedAt          DateTime? @updatedAt
  trainingStartDate  String?
  trainingEndDate    String?
  // Weekly schedule for the Staff Directory working-hours panel.
  // Shape: { Mon: { start: "09:00", end: "18:00" } | null, ..., Sun: ... }
  workingHours       Json?

  @@map("BranchStaff")
}

// Dated history of an employee's weekly working-hours schedule. Each row is a
// version that takes effect on `effectiveFrom` and stays active until a later
// version supersedes it. The attendance report judges each day's Late/Early by
// the version active that day, so editing this/next week never rewrites past
// weeks. BranchStaff.workingHours still holds the latest version as a cache for
// the editor. Written/read via raw SQL (see staff-directory/actions.ts) so it
// works before the generated client is refreshed.
model BranchStaffSchedule {
  id            Int      @id @default(autoincrement())
  branchStaffId Int
  effectiveFrom DateTime @db.Date
  schedule      Json
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  @@unique([branchStaffId, effectiveFrom], map: "uq_branchstaff_eff")
  @@index([branchStaffId, effectiveFrom], map: "idx_bss_staff_eff")
  @@map("BranchStaffSchedule")
}

model AttendanceLog {
  id                Int      @id @default(autoincrement())
  date              String
  empNo             String
  empName           String
  clockInTime       String
  clockInSerialNo   String
  clockInEmailSent  Boolean  @default(false)
  clockOutTime      String?
  clockOutSerialNo  String?
  clockOutEmailSent Boolean  @default(false)
  scannerLocation   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([date, empNo])
}

model LeaveTransaction {
  id                 Int       @id @default(autoincrement())
  EmployeeCode       String?
  LeaveTypeCode      String?
  LeaveTransId       String?
  ApplyDate          DateTime? @db.Timestamp(6)
  ApplyReason        String?
  ApplyStatus        String?
  Attachment         String?
  DayNo              Decimal?
  HourNo             Decimal?
  Days               String?
  Source             String?
  LeaveAdjustmentId  String?
  LeaveDate          DateTime? @db.Date
  FromTime           DateTime? @db.Time(6)
  ToTime             DateTime? @db.Time(6)
  IsHourly           Boolean?
  IsAdjustment       Boolean?
  LeaveCreditId      String?
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  ActionRemark       String?
  RequiredThirdParty Boolean?
  WorkingHours       Int?

  @@unique([LeaveTransId, LeaveDate], map: "unique_leave_trans")
}

model MedicalLeave {
  id           Int       @id @default(autoincrement())
  employeeCode String
  name         String?
  position     String?
  dept         String?
  branch       String?
  leaveDate    DateTime  @db.Date
  reason       String?
  status       String?
  days         String?
  leaveTransId String?   @unique
  attachment   String?
  createdAt    DateTime  @default(now()) @db.Timestamp(6)
}

// ============================================================
// SHARED AUDIT LOG (used by all Ebright modules)
// ============================================================

model core_audit_log {
  id         String   @id @default(uuid())
  tenantId   String?
  userId     String?
  userEmail  String?
  action     String
  entity     String
  entityId   String?
  meta       Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([tenantId, entity, createdAt])
  @@index([userId, createdAt])
}

// ============================================================
// CRM MODULE — Better Auth tables
// ============================================================

model crm_auth_user {
  id            String   @id @default(uuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String?
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions      crm_auth_session[]
  accounts      crm_auth_account[]
  userBranches  crm_user_branch[]
  notifications crm_notification[]
  tasks         crm_task[]
  notes         crm_note[]
  calls         crm_call[]
  apiKeys       crm_api_key[]
  assignedContacts    crm_contact[]    @relation("AssignedUser")
  assignedOpportunities crm_opportunity[] @relation("AssignedUser")
  stageHistories crm_stage_history[]
  automationRuns crm_automation_run[]
  messages      crm_message[]
  appointments  crm_appointment[]
  leadTransfers crm_lead_transfer[]

  @@map("crm_auth_user")
}

model crm_auth_session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user crm_auth_user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("crm_auth_session")
}

model crm_auth_account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user crm_auth_user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("crm_auth_account")
}

model crm_auth_verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("crm_auth_verification")
}

// ============================================================
// CRM CORE MODELS
// ============================================================

model crm_tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches crm_branch[]

  @@map("crm_tenant")
}

model crm_branch {
  id               String   @id @default(uuid())
  tenantId         String
  name             String
  /** Short branch code (e.g. "AMP", "ST", "KD"). Used by the dashboard
   *  bar chart + ticket module. Until the manage-branches feature went in
   *  this lived in a hard-coded map in leads-metrics; now it's a column
   *  so super-admins can add/rename branches without editing source. */
  code             String?
  /** Region letter: 'A' | 'B' | 'C'. Drives the colour bucket on the
   *  super-admin dashboard bar chart. Nullable for branches outside the
   *  canonical regional grouping (e.g. the OD test branch, HR). */
  region           String?
  address          String?
  phone            String?
  email            String?
  operatingHours   Json?
  timezone         String   @default("Asia/Kuala_Lumpur")
  branchManagerId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant           crm_tenant          @relation(fields: [tenantId], references: [id])
  userBranches     crm_user_branch[]
  pipelines        crm_pipeline[]
  contacts         crm_contact[]
  opportunities    crm_opportunity[]
  tasks            crm_task[]
  messages         crm_message[]
  appointments     crm_appointment[]
  automations      crm_automation[]
  integrations     crm_integration[]
  websiteForms     crm_website_form[]
  emailSettings    crm_email_settings?
  whatsappSettings crm_whatsapp_settings?
  tags             crm_tag[]
  customValues     crm_custom_value[]   @relation("BranchCustomValues")
  messageTemplates crm_message_template[]
  transfersFrom    crm_lead_transfer[]  @relation("TransferFrom")
  transfersTo      crm_lead_transfer[]  @relation("TransferTo")
  whatsappLeads    crm_whatsapp_lead[]

  @@index([tenantId])
  @@map("crm_branch")
}

/// Inbound WhatsApp interactions that a branch must process.
///
/// Each row mirrors one interaction from `ebrightleads_db.ws_leads` (anonymous
/// "1 message = 1 potential lead" counts auto-inserted by the Meta WhatsApp
/// pipeline) OR a manual entry added by a super admin. The CRM tracks the
/// resolution state HERE rather than in ws_leads (which is owned by the
/// external auto-system), keyed by `wsLeadId`. COMPLETED/DELETED rows act as
/// tombstones so a re-sync never resurrects a cleared interaction.
///
/// Lifecycle: PENDING → (branch fills the WhatsApp form) COMPLETED, linking the
/// `crm_contact` it created; or → (super admin) DELETED for "just asking"
/// interactions. Only these two transitions clear a branch's red badge.
model crm_whatsapp_lead {
  id          String    @id @default(uuid())
  tenantId    String
  branchId    String
  /// ws_leads.ws_lead_id for auto rows, or "manual_<uuid>" for super-admin adds.
  wsLeadId    String
  /// 'auto' (synced from ws_leads) | 'manual' (super-admin added).
  source      String    @default("auto")
  /// 'PENDING' | 'COMPLETED' | 'DELETED'.
  status      String    @default("PENDING")
  // Snapshot of the ws_leads row at sync time (ws_leads may change/disappear).
  rawBranch   String?
  locationKey String?
  fullName    String?
  phone       String?
  campaignName String?
  submittedAt DateTime?
  // Set when a branch completes the WhatsApp form.
  contactId        String?
  completedByUserId String?
  completedAt       DateTime?
  // Set when a super admin deletes the interaction.
  deletedByUserId String?
  deletedAt       DateTime?
  deleteReason    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branch      crm_branch @relation(fields: [branchId], references: [id])

  @@unique([tenantId, wsLeadId], name: "uq_crm_whatsapp_lead_wsid")
  @@index([tenantId, branchId, status])
  @@map("crm_whatsapp_lead")
}

enum CrmUserRole {
  SUPER_ADMIN
  AGENCY_ADMIN
  REGIONAL_MANAGER
  BRANCH_MANAGER
  BRANCH_STAFF
}

model crm_user_branch {
  id        String      @id @default(uuid())
  userId    String
  branchId  String
  tenantId  String
  role      CrmUserRole
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user   crm_auth_user @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch crm_branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([tenantId])
  @@map("crm_user_branch")
}

model crm_pipeline {
  id        String   @id @default(uuid())
  tenantId  String
  branchId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch        crm_branch        @relation(fields: [branchId], references: [id])
  stages        crm_stage[]
  opportunities crm_opportunity[]

  @@index([tenantId, branchId])
  @@map("crm_pipeline")
}

model crm_stage {
  id         String   @id @default(uuid())
  tenantId   String
  pipelineId String
  name       String
  shortCode  String
  order      Int
  color      String   @default("blue")
  stuckHoursYellow Int @default(24)
  stuckHoursRed    Int @default(48)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pipeline          crm_pipeline        @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  opportunities     crm_opportunity[]
  stageHistoriesFrom crm_stage_history[] @relation("FromStage")
  stageHistoriesTo   crm_stage_history[] @relation("ToStage")

  @@index([tenantId, pipelineId, order])
  @@map("crm_stage")
}

enum TrialDay {
  WED
  THU
  FRI
  SAT
  SUN
}

model crm_contact {
  id                String    @id @default(uuid())
  tenantId          String
  branchId          String
  firstName         String
  lastName          String?
  email             String?
  phone             String?
  leadSourceId      String?
  assignedUserId    String?
  preferredBranchId String?
  preferredTrialDay TrialDay?
  enrolledPackage   String?
  // For sibling-exploded imports (children in master_leads_base.children_details),
  // contact.firstName/lastName holds the CHILD's name and parentFullName holds
  // the parent's. Single-child / no-children imports leave parentFullName null
  // so the card and the modal both show the same name.
  parentFullName    String?
  // Marketing campaign that produced this lead (from master_leads_base.campaign_name).
  // Stored verbatim — display as written, no normalisation. Null = lead didn't
  // come from a tracked campaign; UI renders "-" in that case.
  campaignName      String?
  // Free-text remarks the parent typed on the Wix / trial registration form.
  // Stored directly on the contact (one per sibling) so the lead-detail card
  // can show it without a separate note row. Null when none was entered.
  remarks           String?
  // Raw lead-source label as it arrived from the source system (e.g.
  // "roadshow", "trial-class-e form") BEFORE normalizeSourceName() collapsed
  // it into the canonical bucket on `leadSource`. Lets the lead-detail card
  // show "Others (roadshow)" instead of a flat "Others". Null when the raw
  // label matched the bucket or wasn't captured.
  leadSourceDetail  String?
  childName1        String?
  childAge1         String?
  childName2        String?
  childAge2         String?
  childName3        String?
  childAge3         String?
  childName4        String?
  childAge4         String?
  // Idempotency keys for inbound integration ingest. The pair points back at
  // the source row in ebrightleads_db (e.g. "meta_leads" + "6625556"). The
  // composite unique constraint makes it impossible to ingest the same lead
  // twice — the LISTEN/NOTIFY worker and the polling backstop can race freely
  // without producing duplicates.
  externalSourceTable String?
  externalSourceId    String?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  branch         crm_branch        @relation(fields: [branchId], references: [id])
  leadSource     crm_lead_source?  @relation(fields: [leadSourceId], references: [id])
  assignedUser   crm_auth_user?    @relation("AssignedUser", fields: [assignedUserId], references: [id])
  contactTags    crm_contact_tag[]
  notes          crm_note[]
  tasks          crm_task[]
  calls          crm_call[]
  messages       crm_message[]
  opportunities  crm_opportunity[]
  appointments   crm_appointment[]
  automationRuns crm_automation_run[]

  @@unique([tenantId, externalSourceTable, externalSourceId], name: "uq_crm_contact_external_source")
  @@index([tenantId, branchId])
  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@map("crm_contact")
}

model crm_opportunity {
  id               String    @id @default(uuid())
  tenantId         String
  branchId         String
  contactId        String
  pipelineId       String
  stageId          String
  value            Decimal   @default(0) @db.Decimal(12, 2)
  assignedUserId   String?
  lastStageChangeAt DateTime @default(now())
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  branch        crm_branch         @relation(fields: [branchId], references: [id])
  contact       crm_contact        @relation(fields: [contactId], references: [id])
  pipeline      crm_pipeline       @relation(fields: [pipelineId], references: [id])
  stage         crm_stage          @relation(fields: [stageId], references: [id])
  assignedUser  crm_auth_user?     @relation("AssignedUser", fields: [assignedUserId], references: [id])
  stageHistory  crm_stage_history[]
  leadTransfers crm_lead_transfer[]

  @@index([tenantId, branchId, stageId])
  @@index([tenantId, pipelineId])
  // Kanban fetches a stage's cards filtered by createdAt and ordered by it —
  // this covers the per-column query + ORDER BY without a sort step.
  @@index([tenantId, stageId, createdAt])
  @@map("crm_opportunity")
}

model crm_stage_history {
  id            String   @id @default(uuid())
  tenantId      String
  opportunityId String
  fromStageId   String?
  toStageId     String
  changedByUserId String?
  note          String?
  changedAt     DateTime @default(now())

  opportunity   crm_opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  fromStage     crm_stage?      @relation("FromStage", fields: [fromStageId], references: [id])
  toStage       crm_stage       @relation("ToStage", fields: [toStageId], references: [id])
  changedByUser crm_auth_user?  @relation(fields: [changedByUserId], references: [id])

  @@index([tenantId, opportunityId])
  @@map("crm_stage_history")
}

model crm_lead_transfer {
  id                  String   @id @default(uuid())
  tenantId            String
  opportunityId       String
  fromBranchId        String
  toBranchId          String
  fromPipelineId      String
  toPipelineId        String
  fromStageId         String
  toStageId           String
  transferredByUserId String?
  reason              String
  transferredAt       DateTime @default(now())

  opportunity   crm_opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  fromBranch    crm_branch      @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranch      crm_branch      @relation("TransferTo",   fields: [toBranchId],   references: [id])
  transferredBy crm_auth_user?  @relation(fields: [transferredByUserId], references: [id])

  @@index([tenantId, opportunityId])
  @@map("crm_lead_transfer")
}

model crm_lead_source {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts crm_contact[]

  @@index([tenantId])
  @@map("crm_lead_source")
}

model crm_tag {
  id        String   @id @default(uuid())
  tenantId  String
  branchId  String?
  name      String
  color     String   @default("#3b82f6")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch      crm_branch?       @relation(fields: [branchId], references: [id])
  contactTags crm_contact_tag[]

  @@index([tenantId])
  @@map("crm_tag")
}

model crm_contact_tag {
  id        String   @id @default(uuid())
  contactId String
  tagId     String
  createdAt DateTime @default(now())

  contact crm_contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     crm_tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@map("crm_contact_tag")
}

model crm_note {
  id        String   @id @default(uuid())
  tenantId  String
  contactId String
  userId    String?
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact crm_contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    crm_auth_user? @relation(fields: [userId], references: [id])

  @@index([tenantId, contactId])
  @@map("crm_note")
}

model crm_task {
  id             String    @id @default(uuid())
  tenantId       String
  branchId       String
  contactId      String?
  assignedUserId String?
  title          String
  dueAt          DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  branch       crm_branch?    @relation(fields: [branchId], references: [id])
  contact      crm_contact?   @relation(fields: [contactId], references: [id])
  assignedUser crm_auth_user? @relation(fields: [assignedUserId], references: [id])

  @@index([tenantId, branchId])
  @@index([tenantId, assignedUserId, dueAt])
  @@map("crm_task")
}

enum MessageChannel {
  EMAIL
  WHATSAPP
  SMS
}

enum MessageDirection {
  IN
  OUT
}

model crm_message {
  id                String           @id @default(uuid())
  tenantId          String
  branchId          String
  contactId         String
  userId            String?
  channel           MessageChannel
  direction         MessageDirection
  body              String
  subject           String?
  status            String           @default("pending")
  providerMessageId String?
  errorMessage      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  branch  crm_branch     @relation(fields: [branchId], references: [id])
  contact crm_contact    @relation(fields: [contactId], references: [id])
  user    crm_auth_user? @relation(fields: [userId], references: [id])

  @@index([tenantId, branchId, contactId])
  @@map("crm_message")
}

model crm_call {
  id        String   @id @default(uuid())
  tenantId  String
  contactId String
  userId    String?
  outcome   String?
  notes     String?
  duration  Int?
  createdAt DateTime @default(now())

  contact crm_contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    crm_auth_user? @relation(fields: [userId], references: [id])

  @@index([tenantId, contactId])
  @@map("crm_call")
}

model crm_message_template {
  id        String         @id @default(uuid())
  tenantId  String
  branchId  String?
  name      String
  channel   MessageChannel
  subject   String?
  body      String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  branch crm_branch? @relation(fields: [branchId], references: [id])

  @@index([tenantId])
  @@map("crm_message_template")
}

enum CustomValueScope {
  TENANT
  BRANCH
}

